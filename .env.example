# Skopiuj do `.env` w katalogu głównym (`.env` jest w .gitignore).
# Flutter: flutter build appbundle --release --dart-define-from-file=.env

APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
RC_PUBLIC_KEY_ANDROID=your_revenuecat_public_sdk_key_android
APPWRITE_PRO_GATE_FN_ID=pro_gate

# Opcjonalnie:
# PRIVACY_POLICY_URL=https://example.com/privacy
# TERMS_OF_SERVICE_URL=
# CONSUMER_INFO_URL=
